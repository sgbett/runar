{
  "name": "runar-lang",
  "version": "0.3.1",
  "type": "module",
  "description": "Rúnar smart contract language: base class, types, and builtins",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "default": "./dist/tokens/index.js"
    },
    "./oracle": {
      "types": "./dist/oracle/index.d.ts",
      "default": "./dist/oracle/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "files": ["dist"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/icellan/runar",
    "directory": "packages/runar-lang"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@bsv/sdk": "^2.0.7"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
