    "directory": "packages/runar-compiler"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "ts-morph": "^24.0.0",
    "runar-lang": "workspace:*",
    "runar-ir-schema": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
