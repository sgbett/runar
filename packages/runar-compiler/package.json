{
  "name": "runar-compiler",
  "version": "0.3.1",
  "type": "module",
  "description": "Rúnar reference compiler (TypeScript): nanopass pipeline from TS to Bitcoin Script",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
